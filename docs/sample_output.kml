<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Global Language Distribution Map - Sample Dataset</name>
    <description>A sample of 100 languages with coordinates representing various endangerment statuses.</description>
    <open>1</open>
    <Style id="style-not-endangered">
      <IconStyle>
        <color>ff50af4c</color>
        <scale>1.0</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/shapes/shaded_dot.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <color>ff50af4c</color>
        <scale>0.8</scale>
      </LabelStyle>
      <BalloonStyle>
        <text>
          <![CDATA[<h3>$[name]</h3>$[description]]]>
        </text>
      </BalloonStyle>
    </Style>
    <Style id="style-threatened">
      <IconStyle>
        <color>ff07c1ff</color>
        <scale>1.0</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/shapes/shaded_dot.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <color>ff07c1ff</color>
        <scale>0.8</scale>
      </LabelStyle>
      <BalloonStyle>
        <text>
          <![CDATA[<h3>$[name]</h3>$[description]]]>
        </text>
      </BalloonStyle>
    </Style>
