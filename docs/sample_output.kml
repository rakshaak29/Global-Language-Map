<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Global Language Distribution Map - Sample Dataset</name>
    <description>A sample of 100 languages with coordinates representing various endangerment statuses and dynamic regional highlights.</description>
    <open>1</open>
    <Style id="style-gane1238">
      <IconStyle>
        <color>ff9e9e9e</color>
        <scale>1.0</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/shapes/shaded_dot.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <color>ff9e9e9e</color>
        <scale>0.8</scale>
      </LabelStyle>
      <LineStyle>
        <color>ffd7e330</color>
        <width>2</width>
      </LineStyle>
      <PolyStyle>
        <color>50d7e330</color>
        <fill>1</fill>
        <outline>1</outline>
      </PolyStyle>
      <BalloonStyle>
        <text>
          <![CDATA[<h3>$[name]</h3>$[description]]]>
        </text>
      </BalloonStyle>
    </Style>
